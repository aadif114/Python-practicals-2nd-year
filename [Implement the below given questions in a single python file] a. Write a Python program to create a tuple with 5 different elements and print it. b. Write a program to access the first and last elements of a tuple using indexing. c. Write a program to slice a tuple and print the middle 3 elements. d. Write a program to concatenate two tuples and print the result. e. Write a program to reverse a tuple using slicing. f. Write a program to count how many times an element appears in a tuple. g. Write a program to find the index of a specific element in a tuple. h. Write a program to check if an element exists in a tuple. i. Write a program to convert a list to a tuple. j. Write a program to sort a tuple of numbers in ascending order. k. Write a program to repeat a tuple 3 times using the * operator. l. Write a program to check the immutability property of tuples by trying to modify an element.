
# a. Create a tuple with 5 different elements and print it
my_tuple = (10, 20, 30, 40, 50)
print("a. Tuple:", my_tuple)

# b. Access the first and last elements of a tuple using indexing
print("\nb. First element:", my_tuple[0])
print("Last element:", my_tuple[-1])

# c. Slice a tuple and print the middle 3 elements
print("\nc. Middle 3 elements:", my_tuple[1:4])

# d. Concatenate two tuples and print the result
tuple1 = (1, 2, 3)
tuple2 = (4, 5, 6)
concatenated_tuple = tuple1 + tuple2
print("\nd. Concatenated Tuple:", concatenated_tuple)

# e. Reverse a tuple using slicing
reversed_tuple = my_tuple[::-1]
print("\ne. Reversed Tuple:", reversed_tuple)

# f. Count how many times an element appears in a tuple
count_tuple = (1, 2, 3, 2, 4, 2, 5)
count_element = 2
print("\nf. Count of", count_element, ":", count_tuple.count(count_element))

# g. Find the index of a specific element in a tuple
search_element = 30
print("\ng. Index of", search_element, ":", my_tuple.index(search_element))

# h. Check if an element exists in a tuple
element = 40
if element in my_tuple:
    print("\nh.", element, "exists in the tuple.")
else:
    print("\nh.", element, "does not exist in the tuple.")

# i. Convert a list to a tuple
my_list = [100, 200, 300, 400]
converted_tuple = tuple(my_list)
print("\ni. Converted Tuple:", converted_tuple)

# j. Sort a tuple of numbers in ascending order
unsorted_tuple = (45, 12, 78, 34, 23)
sorted_tuple = tuple(sorted(unsorted_tuple))
print("\nj. Sorted Tuple:", sorted_tuple)

# k. Repeat a tuple 3 times using the * operator
repeat_tuple = (1, 2, 3)
repeated_tuple = repeat_tuple * 3
print("\nk. Repeated Tuple:", repeated_tuple)

# l. Check the immutability property of tuples
print("\nl. Checking Tuple Immutability:")
immutable_tuple = (10, 20, 30)

try:
    immutable_tuple[0] = 100
except TypeError as e:
    print("Error:", e)
    print("Tuples are immutable and cannot be modified.")
